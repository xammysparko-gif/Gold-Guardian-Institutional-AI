//@version=6
indicator(
     title = "Gold Guardian Institutional AI",
     shorttitle = "GG AI",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500)

//=============================================================================
// GOLD GUARDIAN INSTITUTIONAL AI
//-----------------------------------------------------------------------------
// Version  : 15.0
// Release  : Genesis
// Status   : Development
// Author   : D-SAM'S FAMILY + ChatGPT
// Platform : TradingView Pine Script v6
//=============================================================================
// INPUT MANAGER
//=============================================================================

groupGeneral = "General Settings"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
showSignals   = input.bool(true, "Show Trading Signals", group = groupGeneral)
showStructure = input.bool(true, "Show Market Structure", group = groupGeneral)
showVolume    = input.bool(true, "Show Volume Analysis", group = groupGeneral)

//=============================================================================
// THEME
//=============================================================================

bullColor = color.lime
bearColor = color.red
neutralColor = color.gray
dashboardColor = color.black
textColor = color.white

//=============================================================================
// THEME
//=============================================================================

bullColor = color.lime
bearColor = color.red
neutralColor = color.gray
dashboardColor = color.black
textColor = color.white

//=============================================================================
// MAIN LOOP
//=============================================================================

//=============================================================================
// SPRINT 2
// MARKET STRUCTURE ENGINE
//=============================================================================

groupStructure = "Market Structure"

ggShowStructure = input.bool(true, "Show Market Structure", group = groupStructure)
ggSwingLength   = input.int(5, "Swing Length", minval = 2, maxval = 20, group = groupStructure)


//----------------------------------------------------
// Pivot Detection
//----------------------------------------------------

ggPivotHigh = ta.pivothigh(high, ggSwingLength, ggSwingLength)
ggPivotLow  = ta.pivotlow(low, ggSwingLength, ggSwingLength)


//----------------------------------------------------
// Store Previous Swings
//----------------------------------------------------

var float ggPreviousHigh = na
var float ggPreviousLow  = na


//----------------------------------------------------
// Structure Labels
//----------------------------------------------------

if ggShowStructure

    if not na(ggPivotHigh)

        string highType = na(ggPreviousHigh) ? "HH" :
             ggPivotHigh > ggPreviousHigh ? "HH" : "LH"

        label.new(
             bar_index - ggSwingLength,
             ggPivotHigh,
             highType,
             style = label.style_label_down,
             color = highType == "HH" ? color.green : color.red,
             textcolor = color.white,
             size = size.small)

        ggPreviousHigh := ggPivotHigh


    if not na(ggPivotLow)

        string lowType = na(ggPreviousLow) ? "HL" :
             ggPivotLow > ggPreviousLow ? "HL" : "LL"

        label.new(
             bar_index - ggSwingLength,
             ggPivotLow,
             lowType,
             style = label.style_label_up,
             color = lowType == "HL" ? color.green : color.red,
             textcolor = color.white,
             size = size.small)

        ggPreviousLow := ggPivotLow